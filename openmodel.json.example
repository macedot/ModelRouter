{
  "$schema": "https://raw.githubusercontent.com/macedot/openmodel/master/openmodel.schema.json",
  "server": {
    "port": 12345,
    "host": "localhost"
  },
  "providers": {
    "ollama": {
      "url": "http://127.0.0.1:11434/v1",
      "api_mode": "openai",
      "models": [
        "glm-5:cloud",
        "minimax-m2.5:cloud"
      ]
    },
    "opencode": {
      "url": "https://opencode.ai/zen/v1",
      "api_mode": "openai",
      "models": [
        "minimax-m2.5-free",
        "opencode/big-pickle",
        "opencode/gpt-5-nano"
      ]
    }
  },
  "models": {
    "any": {
      "strategy": "fallback",
      "providers": [
        "opencode/minimax-m2.5-free",
        "opencode/big-pickle",
        "opencode/gpt-5-nano",
        "ollama/glm-5:cloud"
      ]
    },
    "glm-5": {
      "strategy": "fallback",
      "providers": [
        "ollama/glm-5:cloud"
      ]
    },
    "minimax-m2.5": {
      "strategy": "fallback",
      "providers": [
        "opencode/minimax-m2.5-free",
        "ollama/minimax-m2.5:cloud"
      ]
    }
  },
  "thresholds": {
    "failures_before_switch": 3,
    "initial_timeout_ms": 10000,
    "max_timeout_ms": 300000
  },
  "log_level": "debug"
}